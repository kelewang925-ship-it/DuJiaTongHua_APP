{
  "name": "dujia-tonghua-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:dev-ui": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-web-dev-ui.ps1",
    "audit:pages": "node scripts/audit-page-structure.mjs",
    "audit:real": "node scripts/audit-real-mode.mjs",
    "test": "jest",
    "test:final": "jest --runInBand --ci && npm run audit:pages && npm run audit:real",
    "check:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package.ps1 -Target web -SkipInstall",
    "package:android": "powershell -ExecutionPolicy Bypass -File ./scripts/package.ps1 -Target android -Profile preview",
    "package:android:preview": "powershell -ExecutionPolicy Bypass -File ./scripts/package.ps1 -Target android -Profile preview",
    "package:android:production": "powershell -ExecutionPolicy Bypass -File ./scripts/package.ps1 -Target android -Profile production",
    "package:web": "powershell -ExecutionPolicy Bypass -File ./scripts/package.ps1 -Target web"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.49.8",
    "expo": "~56.0.11",
    "expo-blur": "56.0.3",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.5",
    "expo-haptics": "56.0.3",
    "expo-image-picker": "~56.0.21",
    "expo-linear-gradient": "56.0.4",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.10",
    "expo-status-bar": "56.0.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-pell-rich-editor": "^1.10.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "^0.8.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@testing-library/react-native": "^14.0.1",
    "jest-expo": "~56.0.0",
    "supabase": "^2.50.5"
  }
}
